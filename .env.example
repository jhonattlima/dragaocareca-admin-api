NODE_ENV=development
PORT=3000
SQLITE_PATH=data/database/dragaocareca-admin.sqlite
SQLITE_RESET=false
GOOGLE_CLIENT_ID=
JWT_SECRET=
JWT_EXPIRES_IN=12h
ALLOWED_GOOGLE_EMAILS=
AUTH_BYPASS=false

# Spotify creator analytics connector
SPOTIFY_METRICS_ENABLED=false
SPOTIFY_PODCAST_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_SP_DC=
SPOTIFY_SP_KEY=
SPOTIFY_METRICS_BASE_URL=https://generic.wg.spotify.com/podcasters/v0
SPOTIFY_METRICS_TIMEOUT_MS=15000
SPOTIFY_METRICS_SAMPLE_INTERVAL_MS=86400000

# YouTube creator analytics connector
YOUTUBE_METRICS_ENABLED=false
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=
YOUTUBE_ANALYTICS_BASE_URL=https://youtubeanalytics.googleapis.com/v2
YOUTUBE_DATA_BASE_URL=https://youtube.googleapis.com/youtube/v3
YOUTUBE_METRICS_TIME_ZONE=America/Sao_Paulo
YOUTUBE_METRICS_TIMEOUT_MS=15000
YOUTUBE_METRICS_SAMPLE_INTERVAL_MS=86400000

# Telegram launch notifications
# Required for the bot to run:
TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_CHAT_ID=-1001234567890
# Optional:
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_POLL_INTERVAL_MS=300000

MEDIA_STORAGE_ROOT=data/media
MEDIA_BACKUP_ROOT=data/media/backups
MEDIA_EPISODES_DIR=data/media/episodes
MEDIA_EPISODES_STAGING_DIR=data/media/episodes/staging
MEDIA_TRAILERS_DIR=data/media/trailers
MEDIA_TRAILERS_STAGING_DIR=data/media/trailers/staging
MEDIA_COVERS_DIR=data/media/images
MEDIA_COVERS_STAGING_DIR=data/media/images/staging
MEDIA_COVERS_LOW_DIR=data/media/images/low
MEDIA_COVERS_LOW_STAGING_DIR=data/media/images/low/staging
MEDIA_BACKUP_EPISODES_DIR=data/media/backups/episodes
MEDIA_BACKUP_EPISODES_AUDIO_DIR=data/media/backups/episodes/audio
MEDIA_BACKUP_EPISODES_TRAILERS_DIR=data/media/backups/episodes/trailers
MEDIA_BACKUP_EPISODES_COVERS_DIR=data/media/backups/episodes/images
MEDIA_BACKUP_EPISODES_COVERS_LOW_DIR=data/media/backups/episodes/images/low

